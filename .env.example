DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dbname?schema=public"
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=3600s

# URL del frontend — a donde redirige el backend tras OAuth exitoso
# Dev:  http://localhost:3000
# Prod: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
# IMPORTANT: Authorized Redirect URI in Google Console must match OAUTH_CALLBACK_URL exactly.
# The callback goes to the BACKEND (port 4000), NOT the frontend (port 3000).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── Apple Sign In ────────────────────────────────────────────────────────────
# Setup guide: https://developer.apple.com/documentation/sign_in_with_apple
#
# Step 1 — Create an App ID with "Sign in with Apple" enabled:
#   Apple Developer → Certificates, IDs & Profiles → Identifiers → App IDs
#
# Step 2 — Create a Service ID (this is your APPLE_CLIENT_ID):
#   Identifiers → Service IDs → Configure → add your domain and Return URLs
#   Return URL must be HTTPS — use ngrok for local dev.
#
# Step 3 — Create a Key with "Sign in with Apple" enabled:
#   Keys → + → Enable "Sign in with Apple" → Download the .p8 key file
#   ⚠️  The .p8 file can only be downloaded ONCE. Store it securely.
#   APPLE_KEY_ID is shown on the key detail page.
#   APPLE_TEAM_ID is in Membership → Team ID (10 characters).
#
# Step 4 — Set APPLE_PRIVATE_KEY to the full content of the .p8 file,
#   with literal \n instead of real newlines (for .env compatibility):
#   APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----"
#
APPLE_CLIENT_ID=com.yourapp.auth
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL=https://your-ngrok.ngrok.io/auth/apple/callback

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Search ───────────────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

NODE_ENV=development
